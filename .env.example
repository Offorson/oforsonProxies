# ============================================
# Oforson Proxies — Environment Variables
# Copy this file to .env.local and fill values
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webshare — sole upstream provider (Static Residential, Rotating Residential, Datacenter)
WEBSHARE_API_KEY=your-webshare-api-key
WEBSHARE_BASE_URL=https://proxy.webshare.io/api/v2
# Residential rotating gateway (powers Rotating Residential proxies)
WEBSHARE_RESIDENTIAL_HOST=p.webshare.io
WEBSHARE_RESIDENTIAL_PORT=80
WEBSHARE_RESIDENTIAL_USERNAME=your-webshare-residential-username
WEBSHARE_RESIDENTIAL_PASSWORD=your-webshare-residential-password

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Oforson Proxies

# NOWPayments (Crypto checkout — sandbox)
NOWPAYMENTS_API_KEY=your-nowpayments-sandbox-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret-key
NOWPAYMENTS_API_URL=https://api-sandbox.nowpayments.io/v1
NEXT_PUBLIC_NOWPAYMENTS_PUBLIC_KEY=your-nowpayments-public-key
USE_MOCK_API=false

# Paystack (Card checkout — multi-currency)
# Set as Supabase Edge Function secrets for create-paystack-checkout + paystack-webhook.
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_API_URL=https://api.paystack.co
# Currency used only when the buying panel sends none — the customer normally picks.
PAYSTACK_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
# Restrict which currencies the buying panel offers (comma-separated ISO codes).
# Set this to only the currencies your Paystack account is actually enabled for.
# Leave unset to offer every Paystack-supported currency.
NEXT_PUBLIC_PAYSTACK_CURRENCIES=USD,NGN,GHS,ZAR,KES

# Live FX rates (USD base) — converts the USD retail total into the charge currency.
# Default source: open.er-api.com (free, no key, ~daily refresh).
# For hourly updates, set an openexchangerates.org app id:
OPENEXCHANGERATES_APP_ID=
# Or point at any custom USD-base feed returning { "rates": { "CUR": number } }:
FX_RATES_URL=
# FX buffer: percentage padding added on top of the live rate so FX drift
# between charge and settlement does not erode margin. Applies to non-USD
# card / bank-transfer charges only. Defaults to 4 when unset; set 0 to disable.
# Also set this as a Supabase Edge Function secret for create-paystack-checkout.
FX_BUFFER_PCT=4
